<Window x:Class="vLauncher.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="vLauncher - Buttoneinstellungen"
        Icon="/Images/vLauncher_Logo_klein.ico"
        Height="400" Width="650"
        WindowStartupLocation="CenterOwner"
        Background="#0F1115">

    <Window.Resources>

        <!-- COLORS -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentColor" Color="#22D3EE"/>
        <SolidColorBrush x:Key="InputBg" Color="#151A22"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2A2F3A"/>

        <!-- =========================
             BUTTON (MODERN)
             ========================= -->
        <Style x:Key="ModernBlueButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>

            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentColor}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- =========================
             TEXTBOX (MODERN DARK INPUT)
             ========================= -->
        <Style TargetType="TextBox">

            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="CaretBrush" Value="#22D3EE"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="13"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">

                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>

                            <!-- Focus -->
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#22D3EE"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>

        </Style>

    </Window.Resources>

    <!-- CONTENT (UNVERÄNDERT) -->
    <Grid Margin="14">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Name des Buttons" Foreground="White"/>
            <TextBox x:Name="TxtButtonName"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,12,0,0">
            <TextBlock Text="Apps / Pfade" Foreground="White"/>
            <TextBox x:Name="TxtApps"
                     AcceptsReturn="True"
                     Height="220"
                     TextChanged="TxtApps_TextChanged"/>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Speichern"
                    Click="vSpeichern"
                    Style="{StaticResource ModernBlueButton}"
                    Width="110"/>

            <Button Content="Abbrechen"
                    Click="vAbbrechen"
                    Style="{StaticResource ModernBlueButton}"
                    Width="110"/>

        </StackPanel>

    </Grid>

</Window>