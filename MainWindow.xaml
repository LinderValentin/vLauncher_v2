<Window x:Class="vLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="vLauncher - Home"
        Icon="/Images/vLauncher_Logo_klein.ico"
        Height="600" Width="1000"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>

        <!-- ===== COLORS ===== -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentColor" Color="#22D3EE"/>
        <SolidColorBrush x:Key="CardBrush" Color="#1C2230"/>

        <!-- ===== BUTTON (BIG MODERN LAUNCHER STYLE) ===== -->
        <Style x:Key="ModernBlueButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>

            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Margin" Value="6"/>

            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentColor}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== DISABLED ===== -->
        <Style x:Key="DisabledButtonStyle"
               BasedOn="{StaticResource ModernBlueButton}"
               TargetType="Button">

            <Setter Property="Background" Value="#2A2F3A"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Opacity" Value="0.85"/>

        </Style>

        <!-- ===== CARD ===== -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="10"/>
        </Style>

    </Window.Resources>

    <!-- 🔥 WINDOW CONTAINER -->
    <Border CornerRadius="16" Background="#0F1115">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- Titlebar -->
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 🔥 CUSTOM TITLEBAR -->
            <Grid Grid.Row="0" Background="#0B0F19" MouseDown="DragWindow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Grid.Column="1">
                    <Button Content="—"
                            Width="40" Height="40"
                            Click="MinimizeWindow"
                            Background="Transparent"
                            Foreground="White"
                            BorderThickness="0"/>

                    <Button Content="✕"
                            Width="40" Height="40"
                            Click="CloseWindow"
                            Foreground="White"
                            BorderThickness="0">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EF4444"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                    </Button>

                </StackPanel>
                <TextBlock Text="vLauncher"
                               VerticalAlignment="Center"
                               Margin="10,0,852,0"
                               FontWeight="Bold"
                               Foreground="White"/>
            </Grid>

            <!-- TOP -->
            <Border Grid.Row="1" Background="#111827" Height="120">
                <DockPanel Margin="18">

                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="vLauncher" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Starte Apps und Dateien mit einem Klick" Foreground="#BFFFFFFF"/>

                        <TextBlock x:Name="UserNameText" Text="Linder Valentin"
                                   FontWeight="SemiBold" Foreground="White" Margin="0,10,0,0"/>

                        <TextBlock x:Name="UserEmailText" Text="linder.vale.2009@gmail.com"
                                   Foreground="#BFFFFFFF"/>
                    </StackPanel>

                    <Image Source="/Images/vLauncher_Logo_klein.ico"
                           Width="64" Height="64"
                           DockPanel.Dock="Right"/>
                </DockPanel>
            </Border>

            <!-- CONTENT -->
            <ScrollViewer Grid.Row="2">
                <StackPanel Margin="24">

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="Headline1" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" Foreground="White" MouseLeftButtonDown="vDoubleClickHeadline"/>
                            <WrapPanel>
                                <Button x:Name="Btn11" Tag="11" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn12" Tag="12" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn13" Tag="13" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn14" Tag="14" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn15" Tag="15" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="Headline2" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"  Foreground="White"/>
                            <WrapPanel>
                                <Button x:Name="Btn21" Tag="21" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn22" Tag="22" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn23" Tag="23" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn24" Tag="24" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn25" Tag="25" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="Headline3" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"  Foreground="White"/>
                            <WrapPanel>
                                <Button x:Name="Btn31" Tag="31" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn32" Tag="32" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn33" Tag="33" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn34" Tag="34" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn35" Tag="35" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock x:Name="Headline4" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"  Foreground="White"/>
                            <WrapPanel>
                                <Button x:Name="Btn41" Tag="41" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn42" Tag="42" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn43" Tag="43" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn44" Tag="44" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                                <Button x:Name="Btn45" Tag="45" Click="vLoadApps" MouseRightButtonUp="vChangeButtons"
                                        Content="unbenutzt" Style="{StaticResource DisabledButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- BOTTOM -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="24">
                <Image x:Name="InfoImage"
                       Source="/Images/info_button.png"
                       Width="64" Height="64"
                       Cursor="Hand"
                       MouseLeftButtonUp="vOpenInfos"/>
                <Image x:Name="MenuIcon"
                    Source="/Images/menue_button.png"
                    Width="64" Height="64"
                    Cursor="Hand"
                    MouseLeftButtonUp="MenuToggle_Click"/>
                <Popup x:Name="MenuPopup"
                    Placement="Relative"
                    StaysOpen="True"
                    AllowsTransparency="True"
                    HorizontalOffset="-115"
                    VerticalOffset="-250">
                    

                    <Popup.PlacementTarget>
                        <Binding ElementName="MenuIcon"/>
                    </Popup.PlacementTarget>

                    <Border Background="#1C2230"
                        CornerRadius="12"
                        Padding="12"
                        Width="180"
                        HorizontalAlignment="Right">

                        <StackPanel>

                            <TextBlock Text="Menü"
                                Foreground="White"
                                FontWeight="Bold"
                                Margin="0,0,0,10"/>

                            <Button Content="Infos"
                                Style="{StaticResource ModernBlueButton}"
                                Click="vOpenInfos"/>

                            <Button Content="Überschriften"
                                Style="{StaticResource ModernBlueButton}"
                                Click="vMenueHeadlines"/>

                            <Button Content="Zurücksetzen"
                                Style="{StaticResource ModernBlueButton}"
                                Click="vMenueReset"/>
                            
                            <Button Content="Beenden"
                                Style="{StaticResource ModernBlueButton}"
                                Click="vCloseSoftware"/>

                        </StackPanel>

                    </Border>
                </Popup>
            </StackPanel>

        </Grid>
    </Border>
</Window>