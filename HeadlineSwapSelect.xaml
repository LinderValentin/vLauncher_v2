<Window x:Class="vLauncher.HeadlineSwapSelect"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="vLauncher - Überschrift tauschen"
        Icon="/Images/vLauncher_Logo_klein.ico"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>

        <!-- COLORS -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentColor" Color="#22D3EE"/>
        <SolidColorBrush x:Key="InputBg" Color="#151A22"/>
        <SolidColorBrush x:Key="BorderColor" Color="#2A2F3A"/>

        <!-- BUTTON -->
        <Style x:Key="ModernBlueButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentColor}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- LISTBOX ITEM STYLE -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F2937"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#22D3EE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- OUTER BORDER (Rounded + Shadow) -->
    <Border Background="#0F1115"
            CornerRadius="14"
            Padding="0">

        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE BAR -->
            <Border Background="#111827"
                    CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Überschrift tauschen mit:"
                               VerticalAlignment="Center"
                               Margin="10,0"
                               Foreground="White"
                               FontWeight="Bold"/>

                    <!-- MINIMIZE -->
                    <StackPanel Orientation="Horizontal" Grid.Column="1">
                        <Button Content="—"
                                Width="40"
                                Height="40"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Click="Minimize_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2A2F3A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <Border Grid.Row="1" Background="#1C2230" Padding="16" Margin="12">

                <Grid Width="300">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TxtSelectedHeadline"
                               Text="Ausgewählte Überschrift:"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#22D3EE"
                               Margin="0,0,0,12"
                               Grid.Row="0"/>

                    <ListBox x:Name="HeadlineListBox"
                             Style="{StaticResource ModernListBox}"
                             MaxHeight="280"
                             Grid.Row="1"
                             Margin="0,0,0,12"/>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button Content="Abbrechen"
                                Click="BtnCancel_Click"
                                Style="{StaticResource ModernBlueButton}"/>

                        <Button Content="Tauschen"
                                Click="BtnSwap_Click"
                                Style="{StaticResource ModernBlueButton}"/>

                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>

</Window>
