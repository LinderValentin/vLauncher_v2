<Window x:Class="vLauncher.YesNoMessage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        Title="Warning"
        Height="230"
        Width="360">

    <Window.Resources>

        <!-- COLORS -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#3B82F6"/>
        <SolidColorBrush x:Key="AccentColor" Color="#22D3EE"/>

        <!-- BUTTON STYLE -->
        <Style x:Key="ModernBlueButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>

            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentColor}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- MAIN CONTAINER -->
    <Border CornerRadius="14"
            Background="#0F1115"
            Padding="18">

        <Border.Effect>
            <DropShadowEffect BlurRadius="20"
                              ShadowDepth="0"
                              Opacity="0.5"/>
        </Border.Effect>

        <Grid>

            <Grid.RowDefinitions>
                <!-- TEXT AREA -->
                <RowDefinition Height="*"/>

                <!-- BUTTON AREA -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TEXT (perfekt zentriert) -->
            <Grid Grid.Row="0">
                <TextBlock x:Name="TxtMessage"
                           Foreground="White"
                           FontSize="14"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Center"
                           Margin="10"/>
            </Grid>

            <!-- BUTTONS -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">

                <Button Content="Ja"
                        Click="BtnYes_Click"
                        Style="{StaticResource ModernBlueButton}"/>

                <Button Content="Nein"
                        Click="BtnNo_Click"
                        Style="{StaticResource ModernBlueButton}"/>

            </StackPanel>

        </Grid>
    </Border>

</Window>