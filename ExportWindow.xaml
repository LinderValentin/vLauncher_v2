<Window x:Class="vLauncher.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Saves" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor">#FF1E88E5</SolidColorBrush>
        <SolidColorBrush x:Key="PrimaryDark">#FF0D47A1</SolidColorBrush>
        <SolidColorBrush x:Key="AccentColor">#FF00E5FF</SolidColorBrush>
        <LinearGradientBrush x:Key="WindowBackground">
            <GradientStop Color="#FF0D47A1" Offset="0" />
            <GradientStop Color="#FF1E88E5" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SurfaceBrush">#FFFFFFFF</SolidColorBrush>
        <SolidColorBrush x:Key="CardBrush">#E8F3FF</SolidColorBrush>

        <Style x:Key="ModernBlueButton" TargetType="Button">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryColor}" />
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryDark}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="root" Background="{TemplateBinding Background}" CornerRadius="8" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="{StaticResource AccentColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="12" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackground}">
        <Border Style="{StaticResource CardStyle}" MaxWidth="560" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12">
            <StackPanel>
                <TextBlock Text="Saves exportieren" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                <TextBlock Text="Wähle einen Speicherort für die ZIP-Datei:" Margin="0,6,0,6" />
                <DockPanel>
                    <TextBox x:Name="TxtZipPath" IsReadOnly="True" MinWidth="360" DockPanel.Dock="Left" />
                    <Button x:Name="BtnBrowse" Content="Durchsuchen" Click="BtnBrowse_Click" Style="{StaticResource ModernBlueButton}" Margin="6,0,0,0" />
                </DockPanel>

                <TextBlock Text="Hinweis: Der gesamte Saves-Ordner wird ins ZIP gepackt." FontSize="12" Opacity="0.9" Margin="0,8,0,12" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Content="Abbrechen" Click="BtnCancel_Click" Style="{StaticResource ModernBlueButton}" />
                    <Button x:Name="BtnExport" Content="Exportieren" Click="BtnExport_Click" Style="{StaticResource ModernBlueButton}" IsEnabled="False" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>